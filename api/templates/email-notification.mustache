<!DOCTYPE html>
<html lang="pl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Nowy subskrybent WikiZEIT</title>
</head>
<body style="margin: 0; padding: 0; font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; background-color: #1a0e0c; color: #f1f5f9;">
    <table width="100%" cellpadding="0" cellspacing="0" style="background-color: #1a0e0c; padding: 40px 20px;">
        <tr>
            <td align="center">
                <table width="600" cellpadding="0" cellspacing="0" style="max-width: 600px; background-color: rgba(180, 33, 4, 0.05); border-radius: 12px; overflow: hidden; border: 1px solid rgba(180, 33, 4, 0.1);">
                    <!-- Header with Logo -->
                    <tr>
                        <td style="padding: 40px 40px 30px 40px;">
                            <table cellpadding="0" cellspacing="0">
                                <tr>
                                    <td>
                                        <div style="display: inline-block; background-color: #b42104; padding: 12px 16px; border-radius: 8px;">
                                            <span style="font-family: Georgia, serif; font-size: 20px; color: #f1f5f9; font-weight: normal;">Wiki</span><span style="font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Arial, sans-serif; font-size: 20px; color: #f1f5f9; font-weight: 700; letter-spacing: 0.05em;">ZEIT</span>
                                        </div>
                                    </td>
                                </tr>
                            </table>
                        </td>
                    </tr>
                    
                    <!-- Content -->
                    <tr>
                        <td style="padding: 0 40px 40px 40px;">
                            <h1 style="margin: 0 0 24px 0; font-size: 28px; font-weight: 700; color: #f1f5f9; line-height: 1.3;">
                                🎉 Nowy subskrybent!
                            </h1>
                            
                            <p style="margin: 0 0 20px 0; font-size: 16px; line-height: 1.6; color: #cbd5e1;">
                                Ktoś właśnie potwierdził swoją subskrypcję newslettera WikiZEIT.
                            </p>
                            
                            <div style="margin: 30px 0; padding: 24px; background-color: rgba(0, 0, 0, 0.3); border-radius: 8px; border-left: 4px solid #b42104;">
                                <p style="margin: 0 0 12px 0; font-size: 14px; color: #94a3b8;">
                                    Email subskrybenta:
                                </p>
                                <p style="margin: 0 0 20px 0; font-size: 18px; font-weight: 600; color: #f1f5f9;">
                                    {{email}}
                                </p>
                                <p style="margin: 0 0 4px 0; font-size: 13px; color: #64748b;">
                                    Data weryfikacji:
                                </p>
                                <p style="margin: 0; font-size: 15px; color: #94a3b8;">
                                    {{verificationDate}}
                                </p>
                            </div>
                            
                            <p style="margin: 30px 0 0 0; font-size: 14px; line-height: 1.6; color: #64748b;">
                                To automatyczna notyfikacja z systemu subskrypcji WikiZEIT.
                            </p>
                        </td>
                    </tr>
                    
                    <!-- Footer -->
                    <tr>
                        <td style="padding: 30px 40px; background-color: #1a0e0c; border-top: 1px solid rgba(180, 33, 4, 0.2);">
                            <p style="margin: 0 0 8px 0; font-size: 13px; color: #64748b; line-height: 1.5;">
                                <strong style="color: #94a3b8;">WikiZEIT</strong><br>
                                System zarządzania subskrybentami
                            </p>
                        </td>
                    </tr>
                </table>
            </td>
        </tr>
    </table>
</body>
</html>
