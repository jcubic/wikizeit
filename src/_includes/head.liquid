<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>{{ title | default: site.title }}</title>
<meta name="description" content="{{ description | default: site.longDescription }}">
<!-- Favicon -->
<link rel="icon" type="image/png" href="{{ '/favicon/favicon-96x96.png' | url }}" sizes="96x96" />
<link rel="icon" type="image/svg+xml" href="{{ '/favicon/favicon.svg' | url }}" />
<link rel="shortcut icon" href="{{ '/favicon/favicon.ico' | url }}" />
<link rel="apple-touch-icon" sizes="180x180" href="{{ '/favicon/apple-touch-icon.png' | url }}" />
<meta name="apple-mobile-web-app-title" content="WikiZEIT" />
<link rel="manifest" href="{{ '/favicon/site.webmanifest' | url }}" />
<!-- Open Graph -->
<meta property="og:url" content="{{ site.url }}{{ page.url }}" />
<meta property="og:type" content="{% if layout == 'layouts/article.liquid' %}article{% else %}website{% endif %}" />
<meta property="og:title" content="{{ title | default: site.title }}" />
<meta property="og:description" content="{{ description | default: site.longDescription }}" />
<meta property="og:image" content="{{ site.baseUrl }}{{ ogImage | default: site.socialImage }}" />
<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta property="twitter:url" content="{{ site.url }}{{ page.url }}" />
<meta name="twitter:title" content="{{ title | default: site.title }}" />
<meta name="twitter:description" content="{{ description | default: site.longDescription }}" />
<meta name="twitter:image" content="{{ site.baseUrl }}{{ ogImage | default: site.socialImage }}" />
<!-- Canonical -->
<link rel="canonical" href="{{ site.url }}{{ page.url }}" />
<!-- Stylesheet -->
<link rel="stylesheet" href="{{ '/css/style.css' | url }}" />
<!-- Fonts -->
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=block" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@100..900&amp;display=swap" rel="stylesheet"/>
<!-- Icon loading (progressive enhancement) -->
<script>
(function() {
    document.documentElement.classList.add('icons-hidden');
    function icons_ready() {
        document.documentElement.classList.remove('icons-hidden');
    }
    if (document.fonts && document.fonts.ready) {
        var font = '24px "Material Symbols Outlined"';
        document.fonts.load(font).then(icons_ready);
    } else {
        icons_ready();
    }
})();
</script>
