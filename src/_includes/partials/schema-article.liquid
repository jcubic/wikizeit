<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@graph": [
    {
      "@type": "{{ person['@type'] }}",
      "url": "{{ person.url }}",
      "@id": "{{ person['@id'] }}",
      "name": "{{ person.name }}",
      "image": "{{ person.image }}",
      "jobTitle": "{{ person.jobTitle }}",
      "sameAs": [
        {% for link in person.sameAs %}"{{ link }}"{% unless forloop.last %},
        {% endunless %}{% endfor %}
      ]
    },
    {
      "@type": "BlogPosting",
      "datePublished": "{{ date | dateFormat: 'iso' }}",
      "dateModified": "{% if modified %}{{ modified | dateFormat: 'iso' }}{% else %}{{ date | dateFormat: 'iso' }}{% endif %}",
      "publisher": {
        "@type": "EducationalOrganization",
        "name": "{{ site.title }}",
        "url": "{{ site.url }}/",
        "logo": {
          "@type": "ImageObject",
          "url": "{{ site.url }}/img/logo.svg"
        }
      },
      "author": { "@id": "{{ site.authorId }}" },
      "headline": "{{ title }}",
      {% if featuredImage %}"image": {
        "@type": "ImageObject",
        "url": "{{ site.url }}{{ featuredImage | url }}"
      },
      {% endif %}"description": "{{ description }}",
      "mainEntityOfPage": {
        "@type": "WebPage",
        "@id": "{{ site.url }}{{ page.url }}#webpage"
      },
      "isPartOf": {
        "@id": "{{ site.url }}{{ page.url }}#webpage"
      }
    },
    {
      "@type": "WebPage",
      "@id": "{{ site.url }}{{ page.url }}#webpage",
      "url": "{{ site.url }}{{ page.url }}",
      "isPartOf": { "@id": "{{ site.url }}/#blog" },
      "breadcrumb": { "@id": "{{ site.url }}{{ page.url }}#breadcrumbs" },
      "mainEntity": { "@id": "{{ site.url }}{{ page.url }}" }
    },
    {
      "@type": "Blog",
      "@id": "{{ site.url }}/#blog",
      "name": "{{ site.title }} Blog",
      "url": "{{ site.url }}/blog/",
      "description": "{{ site.description }}",
      "isPartOf": { "@id": "{{ site.url }}/" },
      "inLanguage": "pl"
    },
    {
      "@type": "WebSite",
      "@id": "https://jcubic.pl#website",
      "url": "https://jcubic.pl",
      "name": "jcubic.pl"
    },
    {
      "@type": "BreadcrumbList",
      "@id": "{{ site.url }}{{ page.url }}#breadcrumbs",
      "itemListElement": [
        {
          "@type": "ListItem",
          "position": 1,
          "item": "https://jcubic.pl#webpage",
          "name": "Głównie JavaScript"
        },
        {
          "@type": "ListItem",
          "position": 2,
          "item": "{{ site.url }}/#webpage",
          "name": "WikiZEIT"
        },
        {
          "@type": "ListItem",
          "position": 3,
          "item": "{{ site.url }}/blog/#webpage",
          "name": "Blog"
        },
        {
          "@type": "ListItem",
          "position": 4,
          "item": "{{ site.url }}{{ page.url }}#webpage",
          "name": "{{ title }}"
        }
      ]
    }
  ]
}
</script>
